# Database — defaults to SQLite (./triage.db) if unset
# DATABASE_URL=postgresql+psycopg2://triage:triage@localhost:5432/triage

# LLM tier (optional — the service falls back to deterministic heuristics without a key)
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...
# LLM_MODEL=claude-haiku-4-5-20251001
